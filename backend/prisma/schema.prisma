generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// Entidad principal multiempresa del sistema
model Company {
  id                  Int                @id @default(autoincrement())
  name                String             @unique @db.VarChar(255)
  slug                String             @unique @db.VarChar(100)
  ruc                 String?            @unique @db.VarChar(20)
  address             String?            @db.VarChar(500)
  phone               String?            @db.VarChar(20)
  email               String?            @db.VarChar(255)
  logo                String?
  website             String?            @db.VarChar(255)
  taxId               String?            @unique @db.VarChar(50)
  legalRepresentative String?            @db.VarChar(255)
  isActive            Boolean            @default(true)
  isDeleted           Boolean            @default(false)
  subscriptionTier    String             @default("FREE") @db.VarChar(50)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?
  auditLogs           AuditLog[]
  branches            Branch[]
  categories          Category[]
  configuration       Configuration?
  customers           Customer[]
  inventory           Inventory[]
  inventoryHistory    InventoryHistory[]
  notifications       Notification[]
  paymentMethods      PaymentMethod_DB[]
  products            Product[]
  purchases           Purchase[]
  sales               Sale[]
  suppliers           Supplier[]
  supportTickets      SupportTicket[]
  units               Unit[]
  users               User[]             @relation("CompanyUsers")

  @@index([isActive])
  @@index([isDeleted])
}
// Gestión de sucursales y sedes empresarialess
model Branch {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(255)
  code             String?            @db.VarChar(20)
  logo             String?
  description      String?
  address          String             @db.VarChar(500)
  phone            String?            @db.VarChar(20)
  email            String?            @db.VarChar(255)
  city             String?            @db.VarChar(100)
  state            String?            @db.VarChar(100)
  country          String?            @db.VarChar(100)
  postalCode       String?            @db.VarChar(20)
  isActive         Boolean            @default(true)
  isDeleted        Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  companyId        Int
  auditLogs        AuditLog[]
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventory        Inventory[]
  inventoryHistory InventoryHistory[]
  purchases        Purchase[]
  sales            Sale[]
  users            User[]             @relation("BranchUsers")

  @@unique([name, companyId])
  @@unique([code, companyId])
  @@index([companyId])
  @@index([isActive])
}
// Gestión centralizada de usuarios del sistemas
model User {
  id               Int              @id @default(autoincrement())
  name             String           @db.VarChar(255)
  email            String           @db.VarChar(255)
  password         String           @db.VarChar(255)
  role             Role             @default(EMPLOYEE)
  phone            String?          @db.VarChar(20)
  avatar           String?
  isActive         Boolean          @default(true)
  isDeleted        Boolean          @default(false)
  isOnline         Boolean          @default(false)
  lastLogin        DateTime?
  lastLogout       DateTime?
  loginAttempts    Int              @default(0)
  lockedUntil      DateTime?
  twoFactorEnabled Boolean          @default(false)
  twoFactorSecret  String?          @db.VarChar(255)
  backupCodes      String?
  managerId        Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  companyId        Int
  branchId         Int?
  auditLogs        AuditLog[]       @relation("UserAudits")
  employeeProfile  EmployeeProfile?
  notifications    Notification[]
  purchases        Purchase[]       @relation("UserPurchases")
  sales            Sale[]           @relation("UserSales")
  assignedTickets  SupportTicket[]  @relation("AssignedTickets")
  supportTickets   SupportTicket[]  @relation("UserTickets")
  ticketComments   TicketComment[]
  branch           Branch?          @relation("BranchUsers", fields: [branchId], references: [id])
  company          Company          @relation("CompanyUsers", fields: [companyId], references: [id], onDelete: Cascade)
  manager          User?            @relation("UserHierarchy", fields: [managerId], references: [id])
  subordinates     User[]           @relation("UserHierarchy")
  sessions         UserSession[]

  @@unique([email, companyId])
  @@index([companyId])
  @@index([branchId])
  @@index([role])
}
// Información laboral complementaria del empleado
model EmployeeProfile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  position   String
  department String
  shift      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
// Administración de sesiones activas de usuario
model UserSession {
  id               Int      @id @default(autoincrement())
  token            String   @unique
  refreshToken     String   @unique
  ipAddress        String?  @db.VarChar(100)
  userAgent        String?  @db.VarChar(500)
  isActive         Boolean  @default(true)
  expiresAt        DateTime
  refreshExpiresAt DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
// Definición de unidades de medida para productoss
model Unit {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(100)
  abbreviation     String    @db.VarChar(20)
  type             UnitType
  conversionFactor Decimal   @default(1) @db.Decimal(10, 4)
  baseUnit         Int?
  isActive         Boolean   @default(true)
  companyId        Int
  products         Product[]
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([abbreviation, companyId])
  @@unique([name, companyId])
}
// Asociación jerárquica de categorías de productos
model Category {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(255)
  description String?    @db.VarChar(500)
  parentId    Int?
  isActive    Boolean    @default(true)
  isDeleted   Boolean    @default(false)
  companyId   Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@unique([name, companyId])
}
// Entidad principal de productos comercializados
model Product {
  id                 Int                @id @default(autoincrement())
  name               String             @db.VarChar(255)
  description        String?
  sku                String?            @db.VarChar(50)
  barcode            String?            @db.VarChar(50)
  purchasePrice      Decimal            @db.Decimal(10, 2)
  salePrice          Decimal            @db.Decimal(10, 2)
  costPrice          Decimal            @db.Decimal(10, 2)
  minStock           Int                @default(5)
  maxStock           Int?
  expirationDate     DateTime?
  batchNumber        String?            @db.VarChar(100)
  requiresExpiration Boolean            @default(false)
  isActive           Boolean            @default(true)
  isDeleted          Boolean            @default(false)
  isFeatured         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  companyId          Int
  categoryId         Int
  unitId             Int
  profitAmount       Decimal            @default(0) @db.Decimal(10, 2)
  profitMargin       Decimal            @default(0) @db.Decimal(10, 2)
  inventory          Inventory[]
  inventoryHistory   InventoryHistory[]
  notifications      Notification[]
  category           Category           @relation(fields: [categoryId], references: [id])
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unit               Unit               @relation(fields: [unitId], references: [id])
  purchaseDetails    PurchaseDetail[]
  saleDetails        SaleDetail[]

  @@unique([sku, companyId])
  @@index([companyId])
  @@index([categoryId])
}
// Gestión de clientes y control de deuda comercial
model Customer {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  documentType   String?   @db.VarChar(20)
  documentNumber String?   @db.VarChar(50)
  email          String?   @db.VarChar(255)
  phone          String?   @db.VarChar(20)
  address        String?   @db.VarChar(500)
  city           String?   @db.VarChar(100)
  notes          String?
  creditLimit    Decimal?  @db.Decimal(10, 2)
  currentDebt    Decimal   @default(0) @db.Decimal(10, 2)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  companyId      Int
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales          Sale[]

  @@unique([documentNumber, companyId])
  @@index([companyId])
  @@index([name])
}
// Información de proveedores asociados a compras
model Supplier {
  id            Int        @id @default(autoincrement())
  name          String     @db.VarChar(255)
  ruc           String?    @db.VarChar(50)
  email         String?    @db.VarChar(255)
  phone         String?    @db.VarChar(20)
  address       String?    @db.VarChar(500)
  contactPerson String?    @db.VarChar(255)
  website       String?    @db.VarChar(255)
  notes         String?
  currentDebt   Decimal    @default(0) @db.Decimal(10, 2)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  companyId     Int
  purchases     Purchase[]
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([name, companyId])
  @@index([companyId])
  @@index([name])
}
// Control de inventario por sucursal y producto
model Inventory {
  id            Int                @id @default(autoincrement())
  stock         Int                @default(0)
  reservedStock Int                @default(0)
  damagedStock  Int                @default(0)
  productId     Int
  branchId      Int
  companyId     Int
  lastUpdated   DateTime           @updatedAt
  createdAt     DateTime           @default(now())
  branch        Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product       Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements     InventoryHistory[]

  @@unique([productId, branchId])
  @@index([branchId])
  @@index([companyId])
}
// Historial de movimientos y variaciones de stock
model InventoryHistory {
  id            Int       @id @default(autoincrement())
  type          String    @db.VarChar(50)
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String?   @db.VarChar(255)
  reference     String?   @db.VarChar(100)
  createdAt     DateTime  @default(now())
  productId     Int
  inventoryId   Int
  branchId      Int
  companyId     Int
  branch        Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventory     Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([branchId])
}
// Configuración de métodos de pago habilitados
model PaymentMethod_DB {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(100)
  type          PaymentMethod
  accountNumber String?       @db.VarChar(50)
  accountHolder String?       @db.VarChar(255)
  isActive      Boolean       @default(true)
  companyId     Int
  payments      Payment[]
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([type, companyId])
}
// Registro centralizado de operaciones de venta
model Sale {
  id         Int          @id @default(autoincrement())
  saleNumber String       @unique @db.VarChar(50)
  total      Decimal      @db.Decimal(10, 2)
  subtotal   Decimal      @db.Decimal(10, 2)
  tax        Decimal      @default(0) @db.Decimal(10, 2)
  discount   Decimal      @default(0) @db.Decimal(10, 2)
  status     SaleStatus   @default(COMPLETED)
  notes      String?      @db.VarChar(500)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  sellerId   Int
  branchId   Int
  companyId  Int
  customerId Int?
  payments   Payment[]
  branch     Branch       @relation(fields: [branchId], references: [id])
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer?    @relation(fields: [customerId], references: [id])
  seller     User         @relation("UserSales", fields: [sellerId], references: [id])
  details    SaleDetail[]

  @@index([companyId])
  @@index([branchId])
  @@index([status])
}
// Registro detallado de productos vendidos
model SaleDetail {
  id        Int     @id @default(autoincrement())
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  tax       Decimal @default(0) @db.Decimal(10, 2)
  saleId    Int
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}
// Registro de adquisiciones y compras empresariales
model Purchase {
  id               Int              @id @default(autoincrement())
  purchaseNumber   String           @unique @db.VarChar(50)
  total            Decimal          @db.Decimal(10, 2)
  subtotal         Decimal          @db.Decimal(10, 2)
  tax              Decimal          @default(0) @db.Decimal(10, 2)
  discount         Decimal          @default(0) @db.Decimal(10, 2)
  status           PurchaseStatus   @default(COMPLETED)
  notes            String?          @db.VarChar(500)
  expectedDelivery DateTime?
  actualDelivery   DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  buyerId          Int
  branchId         Int
  companyId        Int
  supplierId       Int?
  payments         Payment[]
  branch           Branch           @relation(fields: [branchId], references: [id])
  buyer            User             @relation("UserPurchases", fields: [buyerId], references: [id])
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier         Supplier?        @relation(fields: [supplierId], references: [id])
  details          PurchaseDetail[]

  @@index([companyId])
  @@index([branchId])
  @@index([status])
}

model PurchaseDetail {
  id         Int      @id @default(autoincrement())
  quantity   Int
  price      Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  tax        Decimal  @default(0) @db.Decimal(10, 2)
  purchaseId Int
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([productId])
}
// Relación entre métodos de pago y transacciones
model Payment {
  id            Int              @id @default(autoincrement())
  amount        Decimal          @db.Decimal(10, 2)
  status        PaymentStatus    @default(PENDING)
  paymentMethod Int
  reference     String?          @db.VarChar(100)
  notes         String?          @db.VarChar(500)
  transactionId String?          @db.VarChar(100)
  paidAt        DateTime?
  dueDate       DateTime?
  saleId        Int?
  purchaseId    Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  method        PaymentMethod_DB @relation(fields: [paymentMethod], references: [id])
  purchase      Purchase?        @relation(fields: [purchaseId], references: [id])
  sale          Sale?            @relation(fields: [saleId], references: [id])
}

model Notification {
  id        Int              @id @default(autoincrement())
  title     String           @db.VarChar(255)
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  userId    Int
  productId Int?
  companyId Int
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product   Product?         @relation(fields: [productId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}
// Persistencia de eventos críticos y trazabilidad
model AuditLog {
  id          Int         @id @default(autoincrement())
  action      AuditAction
  entityType  String      @db.VarChar(100)
  entityId    Int
  description String?     @db.VarChar(500)
  oldValues   Json?
  newValues   Json?
  ipAddress   String?     @db.VarChar(50)
  userAgent   String?     @db.VarChar(500)
  createdAt   DateTime    @default(now())
  userId      Int?
  branchId    Int?
  companyId   Int
  branch      Branch?     @relation(fields: [branchId], references: [id])
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?       @relation("UserAudits", fields: [userId], references: [id])
}
// Sistema de soporte y seguimiento de incidencias
model SupportTicket {
  id              Int             @id @default(autoincrement())
  ticketNumber    String          @unique @db.VarChar(50)
  title           String          @db.VarChar(255)
  description     String
  status          TicketStatus    @default(OPEN)
  priority        TicketPriority  @default(MEDIUM)
  attachments     String?
  resolutionNotes String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  resolvedAt      DateTime?
  userId          Int
  assignedTo      Int?
  companyId       Int
  assignedUser    User?           @relation("AssignedTickets", fields: [assignedTo], references: [id])
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User            @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  comments        TicketComment[]
}

model TicketComment {
  id          Int           @id @default(autoincrement())
  message     String
  attachments String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ticketId    Int
  userId      Int
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}
// Configuración global personalizable por empresa
model Configuration {
  id                    Int      @id @default(autoincrement())
  companyName           String?  @db.VarChar(255)
  logo                  String?  @db.VarChar(500)
  theme                 String   @default("light") @db.VarChar(50)
  language              String   @default("es") @db.VarChar(10)
  taxRate               Decimal  @default(0) @db.Decimal(5, 2)
  currency              String   @default("PEN") @db.VarChar(10)
  defaultTaxEnabled     Boolean  @default(true)
  notifyLowStock        Boolean  @default(true)
  lowStockThreshold     Int      @default(5)
  notifyExpiring        Boolean  @default(true)
  expiringDaysAlert     Int      @default(30)
  requireTwoFactor      Boolean  @default(false)
  sessionTimeout        Int      @default(3600)
  passwordMinLength     Int      @default(8)
  passwordExpiresDays   Int?
  requirePasswordChange Boolean  @default(false)
  allowMultipleLogins   Boolean  @default(true)
  autoBackup            Boolean  @default(true)
  backupFrequency       String   @default("DAILY") @db.VarChar(50)
  maxLoginAttempts      Int      @default(5)
  allowExport           Boolean  @default(true)
  allowImport           Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  companyId             Int      @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
// Definición de permisos y jerarquías del sistema
enum Role {
  ADMIN
  MANAGER
  SUPERVISOR
  EMPLOYEE
  VIEWER
}

enum PaymentMethod {
  CASH
  CARD
  CHECK
  TRANSFER
  WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  PARTIAL
}
// Enumeración de estados operativos para ventass
enum SaleStatus {
  DRAFT
  PENDING
  COMPLETED
  CANCELLED
  RETURNED
  ARCHIVED
}

enum PurchaseStatus {
  DRAFT
  PENDING
  RECEIVED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum NotificationType {
  EXPIRING_PRODUCT
  LOW_STOCK
  SYSTEM_ALERT
  PURCHASE_READY
  USER_ALERT
  INVENTORY_MISMATCH
  PAYMENT_OVERDUE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  RESTORE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
  REOPENED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UnitType {
  LITER
  HALF_LITER
  QUARTER_LITER
  MILLILITER
  GRAM
  KILOGRAM
  UNIT
  BOX
  PACK
  DOZEN
  METER
  SQUARE_METER
}
